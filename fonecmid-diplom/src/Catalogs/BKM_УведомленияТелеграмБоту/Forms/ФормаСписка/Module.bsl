
&НаКлиенте
Процедура ВыполнитьОтправкуВТГ(Команда)
	
	// Извещаем пользователя, чтобы он не нажимал кнопку дважды
	Состояние("Отправка сообщений в Telegram, подождите...");
	
	ВыполнитьОтправкуВТГНаСервере();
	
	// Обновляем список на экране, чтобы отправленные сообщения сразу исчезли
	Элементы.Список.Обновить();
	
КонецПроцедуры

&НаСервере
Процедура ВыполнитьОтправкуВТГНаСервере()
	
	BKM_Телеграм.ОтправитьУведомленияВТелеграм();
	
КонецПроцедуры
